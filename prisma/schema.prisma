// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GUEST
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  CREDIT_CARD
  PAYPAL
}

enum GalleryCategory {
  VILLA
  DINING
  RESORT
  ACTIVITIES
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(GUEST)
  password      String? // hashed, only used by the Credentials provider
  accounts      Account[]
  sessions      Session[]
  bookings      Booking[]
  createdAt     DateTime  @default(now())
}

// Standard Auth.js Prisma-adapter models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Resort {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  address       String?
  city          String?
  country       String?
  villas        Villa[]
  dinings       Dining[]
  galleryImages GalleryImage[]
  createdAt     DateTime       @default(now())
}

model Villa {
  id                String         @id @default(cuid())
  resortId          String
  resort            Resort         @relation(fields: [resortId], references: [id], onDelete: Cascade)
  name              String
  slug              String         @unique
  description       String?
  basePricePerNight Decimal        @db.Decimal(10, 2)
  capacity          Int
  totalRooms        Int            @default(1)
  amenities         Amenity[]      @relation("VillaAmenities")
  images            GalleryImage[]
  bookings          Booking[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model Dining {
  id           String         @id @default(cuid())
  resortId     String
  resort       Resort         @relation(fields: [resortId], references: [id], onDelete: Cascade)
  name         String
  slug         String         @unique
  description  String?
  cuisineType  String?
  openingHours String?
  images       GalleryImage[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Amenity {
  id     String  @id @default(cuid())
  name   String  @unique
  icon   String?
  villas Villa[] @relation("VillaAmenities")
}

// Unified image store for the whole site. RESORT/ACTIVITIES images are
// resort-wide (no villaId/diningId); VILLA/DINING images are linked to a
// specific villa or dining venue in addition to their category.
model GalleryImage {
  id        String          @id @default(cuid())
  url       String
  path      String? // Supabase Storage object path (null for externally-hosted/seed images)
  category  GalleryCategory
  caption   String?
  order     Int             @default(0)
  resortId  String
  resort    Resort          @relation(fields: [resortId], references: [id], onDelete: Cascade)
  villaId   String?
  villa     Villa?          @relation(fields: [villaId], references: [id], onDelete: Cascade)
  diningId  String?
  dining    Dining?         @relation(fields: [diningId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@index([category])
}

model Booking {
  id                      String        @id @default(cuid())
  userId                  String?
  user                    User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  villaId                 String
  villa                   Villa         @relation(fields: [villaId], references: [id])
  checkIn                 DateTime      @db.Date
  checkOut                DateTime      @db.Date
  guests                  Int
  guestName               String
  guestEmail              String
  guestPhone              String
  paymentMethod           PaymentMethod
  status                  BookingStatus @default(PENDING)
  totalPrice              Decimal       @db.Decimal(10, 2)
  guestNotes              String?
  paymentRef              String? // reserved for a future Stripe payment_intent id — unused in v1
  confirmationEmailSentAt DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([villaId, checkIn, checkOut])
  @@index([guestEmail])
}
