# Copy this file to .env and fill in real values. Never commit .env.

# Supabase Postgres — pooled connection (Supavisor/PgBouncer, port 6543).
# Used by the running app (src/lib/prisma.ts) via the pg driver adapter.
# Append ?pgbouncer=true&connection_limit=1 (recommended for serverless).
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct connection (port 5432).
# Used only by the Prisma CLI (migrate, db push, studio) via prisma.config.ts.
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Auth.js (next-auth@beta)
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# Resend (booking confirmation emails)
RESEND_API_KEY=""
EMAIL_FROM="Islaverde Resort <onboarding@resend.dev>"
